{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default Configure",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-mingw",
      "displayName": "Windows MinGW Configure",
      "generator": "MinGW Makefiles",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_COMPILER": "g++"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "displayName": "Default Build",
      "configurePreset": "default"
    },
    {
      "name": "windows-mingw",
      "displayName": "Windows MinGW Build",
      "configurePreset": "windows-mingw"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "displayName": "Default Test",
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-mingw",
      "displayName": "Windows MinGW Test",
      "configurePreset": "windows-mingw",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
